generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id          Int               @id
  name        String?
  code        String?
  city        String?
  homeGames   Game[]            @relation("HomeTeam")
  awayGames   Game[]            @relation("AwayTeam")
  playerStats PlayerGameStat[]
}

model Game {
  id                   String            @id @default(cuid())
  sourceGameId         Int               @unique    // balldontlie game ID
  nbaGameId            String?           @unique    // NBA.com game ID (e.g., "0022400829")
  date                 DateTime          @db.Date
  season               Int
  stage                Int
  league               String
  homeTeamId           Int
  awayTeamId           Int
  homeScore            Int
  awayScore            Int
  periods              Int?              // 4 = regulation, 5+ = OT
  status               String?           // Final, Final/OT, Scheduled, etc.
  gameCode             String?           // e.g., "20250115/NYKPHI"
  tipoffTimeUtc        DateTime?
  homeTeamNameSnapshot String?
  awayTeamNameSnapshot String?
  seasonType           String?           // REG, POST, PRE, ASG
  isNeutralSite        Boolean?          // Neutral site game
  seriesText           String?           // Playoff series info
  poRoundDesc          String?           // Playoff round description
  homeWinsPreGame      Int?              // Home team wins entering game
  homeLossesPreGame    Int?              // Home team losses entering game
  awayWinsPreGame      Int?              // Away team wins entering game
  awayLossesPreGame    Int?              // Away team losses entering game
  broadcasts           Json?             // TV broadcast info as JSON
  homeTeam             Team              @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam             Team              @relation("AwayTeam", fields: [awayTeamId], references: [id])
  playerStats          PlayerGameStat[]
  odds                 GameOdds[]
  playerPropOdds       PlayerPropOdds[]
  context              GameContext?
  gameEvents           GameEvent[]
  playerContexts       PlayerGameContext[]
  gamePatternHits      GamePatternHit[]

  @@index([date])
  @@index([season, date])
  @@index([homeTeamId, date])
  @@index([awayTeamId, date])
}

model Player {
  id           Int                @id
  firstname    String?
  lastname     String?
  jerseyNum    String?            // Jersey number
  slug         String?            // URL slug (e.g., "lebron-james")
  stats        PlayerGameStat[]
  gameContexts PlayerGameContext[]
  propOdds     PlayerPropOdds[]
}

model PlayerGameStat {
  id          String  @id @default(cuid())
  gameId      String
  playerId    Int
  teamId      Int
  minutes     Int              // Minutes played (integer)
  minutesRaw  String?          // Raw minutes string (e.g., "34:27")
  points      Int
  assists     Int
  rebounds    Int
  steals      Int
  blocks      Int
  turnovers   Int
  fgm         Int?
  fga         Int?
  fgPct       Float?           // Field goal percentage
  fg3m        Int?
  fg3a        Int?
  fg3Pct      Float?           // 3-point percentage
  ftm         Int?
  fta         Int?
  ftPct       Float?           // Free throw percentage
  oreb        Int?
  dreb        Int?
  pf          Int?
  plusMinus   Float?
  position    String?          // G, F, C, G-F, etc.
  starter     Boolean?         // true if started the game
  comment     String?          // DNP reason, injury notes
  game        Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player      Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team        Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
  @@index([gameId])
  @@index([playerId])
  @@index([teamId])
}

model NightEvent {
  id       String   @id @default(cuid())
  date     DateTime @db.Date
  season   Int
  eventKey String
  value    Boolean  @default(true)
  meta     Json?

  @@unique([date, eventKey])
  @@index([season, date])
  @@index([eventKey, date])
}

model Pattern {
  id               String       @id @default(cuid())
  patternKey       String       @unique
  eventKeys        String[]
  legs             Int
  occurrences      Int
  seasons          Int
  perSeason        Json
  longestGapDays   Int?
  lastHitDate      DateTime?    @db.Date
  stabilityScore   Float?
  rarityScore      Float?
  balanceScore     Float?
  recencyScore     Float?
  overallScore     Float?
  createdAt        DateTime           @default(now())
  hits             PatternHit[]
  watchlist        PatternWatchlist?

  @@index([legs, occurrences])
  @@index([overallScore])
}

model PatternHit {
  id        String   @id @default(cuid())
  patternId String
  date      DateTime @db.Date
  season    Int
  meta      Json?
  pattern   Pattern  @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@unique([patternId, date])
  @@index([date])
}

model OrphanPlayerStat {
  id           String   @id @default(cuid())
  sourceGameId Int
  season       Int?
  stage        Int?
  league       String?
  teamId       Int
  playerId     Int?
  reason       String
  createdAt    DateTime @default(now())

  @@index([sourceGameId])
  @@index([reason])
  @@index([season])
}

model PatternWatchlist {
  id        String   @id @default(cuid())
  patternId String
  notes     String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  pattern   Pattern  @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@unique([patternId])
}

model Night {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  season            Int
  gameCount         Int
  statCount         Int
  eventHitCount     Int
  eventLogicVersion String?
  processedAt       DateTime @default(now())

  @@index([season])
}

model NightTeamAggregate {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  season    Int
  teamId    Int
  points    Int
  rebounds  Int
  assists   Int
  steals    Int
  blocks    Int
  turnovers Int
  minutes   Int

  @@unique([date, teamId])
  @@index([season, date])
  @@index([teamId, date])
}

model GameOdds {
  id         String   @id @default(cuid())
  gameId     String
  source     String
  spreadHome Float?
  spreadAway Float?
  totalOver  Float?
  totalUnder Float?
  mlHome     Int?
  mlAway     Int?
  fetchedAt  DateTime @default(now())
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, source])
  @@index([gameId])
}

model PlayerPropOdds {
  id          String   @id @default(cuid())
  gameId      String
  playerId    Int
  source      String              // bookmaker key (fanduel, draftkings, etc.)
  market      String              // player_points, player_rebounds, player_assists, etc.
  line        Float?              // The O/U line (e.g., 24.5)
  overPrice   Int?                // American odds for over (e.g., -110)
  underPrice  Int?                // American odds for under (e.g., -110)
  fetchedAt   DateTime @default(now())
  
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId, source, market])
  @@index([gameId])
  @@index([playerId])
  @@index([market])
}

model ExternalIdMap {
  id         String   @id @default(cuid())
  entityType String   // TEAM, PLAYER, GAME
  source     String   // apiSports, oddsApi, sportradar, etc.
  sourceId   String
  internalId String   // Prefixed: "team:14", "player:2544", "game:ck..."
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, source, sourceId])
  @@index([entityType, internalId])
  @@index([source, entityType])
}

model GameContext {
  id           String  @id @default(cuid())
  gameId       String  @unique

  homeWins     Int
  homeLosses   Int
  homePpg      Float
  homeOppg     Float
  homePace     Float?
  homeRebPg    Float?
  homeAstPg    Float?
  homeFg3Pct   Float?
  homeFtPct    Float?
  homeRankOff  Int?
  homeRankDef  Int?
  homeRankPace Int?
  homeStreak   Int?

  awayWins     Int
  awayLosses   Int
  awayPpg      Float
  awayOppg     Float
  awayPace     Float?
  awayRebPg    Float?
  awayAstPg    Float?
  awayFg3Pct   Float?
  awayFtPct    Float?
  awayRankOff  Int?
  awayRankDef  Int?
  awayRankPace Int?
  awayStreak   Int?

  homeRestDays Int?
  awayRestDays Int?
  homeIsB2b    Boolean @default(false)
  awayIsB2b    Boolean @default(false)

  h2hHomeWins  Int     @default(0)
  h2hAwayWins  Int     @default(0)

  game         Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model PlayerGameContext {
  id          String @id @default(cuid())
  gameId      String
  playerId    Int
  teamId      Int

  gamesPlayed Int
  ppg         Float
  rpg         Float
  apg         Float
  mpg         Float
  fg3Pct      Float?
  ftPct       Float?
  last5Ppg    Float?
  rankPpg     Int?
  rankRpg     Int?
  rankApg     Int?
  oppRankDef  Int?

  game        Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player      Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
  @@index([playerId, gameId])
}

model GameEvent {
  id       String @id @default(cuid())
  gameId   String
  season   Int
  eventKey String
  type     String            // "condition" or "outcome"
  side     String @default("game") // "home", "away", or "game"
  meta     Json?

  game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, eventKey, side])
  @@index([eventKey])
  @@index([season])
  @@index([gameId])
  @@index([type, eventKey])
}

model GamePattern {
  id              String           @id @default(cuid())
  patternKey      String           @unique
  conditions      String[]
  outcome         String
  sampleSize      Int
  hitCount        Int
  hitRate         Float
  seasons         Int
  perSeason       Json
  lastHitDate     DateTime?        @db.Date
  confidenceScore Float?
  valueScore      Float?
  createdAt       DateTime         @default(now())
  hits            GamePatternHit[]

  @@index([outcome])
  @@index([hitRate])
  @@index([confidenceScore])
}

model GamePatternHit {
  id        String      @id @default(cuid())
  patternId String
  gameId    String
  season    Int
  hit       Boolean
  pattern   GamePattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  game      Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([patternId, gameId])
  @@index([gameId])
}

model BacktestRun {
  id              String           @id @default(cuid())
  name            String?
  trainSeasons    Int[]
  testSeasons     Int[]
  config          Json
  totalPatterns   Int
  passingPatterns Int
  aggregatePnL    Float
  aggregateROI    Float
  avgHitRate      Float
  runtimeMs       Int
  completedAt     DateTime         @default(now())
  results         BacktestResult[]

  @@index([completedAt])
}

model BacktestResult {
  id              String      @id @default(cuid())
  runId           String
  patternKey      String
  conditions      String[]
  outcome         String
  trainHitRate    Float
  trainSampleSize Int
  testHitRate     Float
  testSampleSize  Int
  zScoreVsChance  Float
  pValueVsChance  Float
  zScoreVsTrain   Float
  pValueVsTrain   Float
  isSignificant   Boolean
  isConsistent    Boolean
  pnlROI          Float
  pnlNetPnL       Float
  maxDrawdown     Float
  sharpeRatio     Float?
  grade           String
  gradeScore      Int
  run             BacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, patternKey])
  @@index([grade])
  @@index([pnlROI])
}
